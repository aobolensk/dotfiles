root = true

[*]
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[{**.{py,json}}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2

[dotfiles/.config/i3/**]
indent_style = space
indent_size = 8

[{dotfiles/.bashrc,dotfiles/.bash_aliases}]
indent_style = space
indent_size = 4

[dotfiles/.gitconfig]
indent_style = tabs
indent_size = 4
